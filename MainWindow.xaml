<Window x:Class="TaskManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Manager"
        Height="650"
        Width="950"
        Background="#1E1E1E"
        Foreground="#E0E0E0"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif">

    <Grid Margin="10">
        <TabControl Background="#252526"
                    BorderBrush="#3E3E42"
                    Foreground="White">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding"
                            Value="20,10"/>
                    <Setter Property="Background"
                            Value="#2D2D30"/>
                    <Setter Property="Foreground"
                            Value="White"/>
                    <Setter Property="BorderBrush"
                            Value="Transparent"/>
                    <Setter Property="FontSize"
                            Value="14"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected"
                                 Value="True">
                            <Setter Property="Background"
                                    Value="#3E3E42"/>
                            <Setter Property="Foreground"
                                    Value="#66B2FF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <TabItem Header="Processes">
                <Grid Margin="10">
                    <DataGrid x:Name="ProcessGrid"
                              AutoGenerateColumns="False"
                              Background="#1E1E1E"
                              RowBackground="#252526"
                              AlternatingRowBackground="#2D2D30"
                              Foreground="White"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#3E3E42"
                              BorderThickness="1"
                              BorderBrush="#3E3E42">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"
                                        Value="#3E3E42"/>
                                <Setter Property="Foreground"
                                        Value="White"/>
                                <Setter Property="Padding"
                                        Value="10,8"/>
                                <Setter Property="FontWeight"
                                        Value="SemiBold"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Procces Name"
                                                Binding="{Binding ProcessName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="PID"
                                                Binding="{Binding Id}"
                                                Width="100"/>
                            <DataGridTextColumn Header="RAM (MB)"
                                                Binding="{Binding WorkingSet64}"
                                                Width="120"/>
                            <DataGridTemplateColumn Header="Action"
                                                    Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Kill"
                                                Click="KillButton"
                                                Background="#D13438"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Padding="10,4"
                                                Cursor="Hand"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Performance">
                <TabControl TabStripPlacement="Left"
                            Background="#1E1E1E"
                            BorderThickness="0,0,1,0"
                            BorderBrush="#3E3E42">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Padding"
                                    Value="15,15"/>
                            <Setter Property="Background"
                                    Value="Transparent"/>
                            <Setter Property="Foreground"
                                    Value="White"/>
                            <Setter Property="BorderThickness"
                                    Value="0"/>
                            <Setter Property="HorizontalAlignment"
                                    Value="Stretch"/>
                            <Setter Property="FontSize"
                                    Value="14"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="#3E3E42"/>
                                    <Setter Property="Foreground"
                                            Value="#66B2FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Resources>

                    <TabItem Header="💻 CPU">
                        <Grid Margin="30">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="CpuName"
                                       Grid.Row="0"
                                       Text="AMD Ryzen 5 3600 6-Core Processor"
                                       Foreground="#E0E0E0"
                                       FontSize="16"
                                       HorizontalAlignment="Right"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,20"/>

                            <Grid Grid.Row="1"
                                  Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Margin="0,0,60,0">
                                    <StackPanel Margin="0,0,30,0">
                                        <TextBlock Text="Utilization"
                                                   Foreground="#A0A0A0"
                                                   FontSize="14"/>
                                        <TextBlock x:Name="CpuPercentage"
                                                   Text="10%"
                                                   FontSize="42"
                                                   Foreground="White"
                                                   FontWeight="Light"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Speed"
                                                   Foreground="#A0A0A0"
                                                   FontSize="14"/>
                                        <TextBlock x:Name="CpuSpeed"
                                                   Text="4,20 GHz"
                                                   FontSize="42"
                                                   Foreground="White"
                                                   FontWeight="Light"/>
                                    </StackPanel>
                                </StackPanel>

                                <Grid Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Base speed:"
                                               Foreground="#A0A0A0"
                                               Margin="0,0,30,6"
                                               FontSize="13"/>
                                    <TextBlock x:Name="BaseSpeedText"
                                               Grid.Row="0"
                                               Grid.Column="1"
                                               Text="4,20 GHz"
                                               Foreground="White"
                                               Margin="0,0,0,6"
                                               FontSize="13"/>

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="Sockets:"
                                               Foreground="#A0A0A0"
                                               Margin="0,0,30,6"
                                               FontSize="13"/>
                                    <TextBlock x:Name="SocketsText"
                                               Grid.Row="1"
                                               Grid.Column="1"
                                               Text="1"
                                               Foreground="White"
                                               Margin="0,0,0,6"
                                               FontSize="13"/>

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Text="Cores:"
                                               Foreground="#A0A0A0"
                                               Margin="0,0,30,6"
                                               FontSize="13"/>
                                    <TextBlock x:Name="CoresText"
                                               Grid.Row="2"
                                               Grid.Column="1"
                                               Text="6"
                                               Foreground="White"
                                               Margin="0,0,0,6"
                                               FontSize="13"/>

                                    <TextBlock Grid.Row="3"
                                               Grid.Column="0"
                                               Text="Logical processors:"
                                               Foreground="#A0A0A0"
                                               Margin="0,0,30,6"
                                               FontSize="13"/>
                                    <TextBlock x:Name="LogicalProcText"
                                               Grid.Row="3"
                                               Grid.Column="1"
                                               Text="12"
                                               Foreground="White"
                                               Margin="0,0,0,6"
                                               FontSize="13"/>

                                    <TextBlock Grid.Row="4"
                                               Grid.Column="0"
                                               Text="Virtualization:"
                                               Foreground="#A0A0A0"
                                               Margin="0,0,30,6"
                                               FontSize="13"/>
                                    <TextBlock x:Name="VirtualizationText"
                                               Grid.Row="4"
                                               Grid.Column="1"
                                               Text="Enabled"
                                               Foreground="White"
                                               Margin="0,0,0,6"
                                               FontSize="13"/>

                                    <TextBlock Grid.Row="5"
                                               Grid.Column="0"
                                               Text="L1 cache:"
                                               Foreground="#A0A0A0"
                                               Margin="0,0,30,6"
                                               FontSize="13"/>
                                    <TextBlock x:Name="L1CacheText"
                                               Grid.Row="5"
                                               Grid.Column="1"
                                               Text="384 KB"
                                               Foreground="White"
                                               Margin="0,0,0,6"
                                               FontSize="13"/>

                                    <TextBlock Grid.Row="6"
                                               Grid.Column="0"
                                               Text="L2 cache:"
                                               Foreground="#A0A0A0"
                                               Margin="0,0,30,6"
                                               FontSize="13"/>
                                    <TextBlock x:Name="L2CacheText"
                                               Grid.Row="6"
                                               Grid.Column="1"
                                               Text="3,0 MB"
                                               Foreground="White"
                                               Margin="0,0,0,6"
                                               FontSize="13"/>

                                    <TextBlock Grid.Row="7"
                                               Grid.Column="0"
                                               Text="L3 cache:"
                                               Foreground="#A0A0A0"
                                               Margin="0,0,30,6"
                                               FontSize="13"/>
                                    <TextBlock x:Name="L3CacheText"
                                               Grid.Row="7"
                                               Grid.Column="1"
                                               Text="32,0 MB"
                                               Foreground="White"
                                               Margin="0,0,0,6"
                                               FontSize="13"/>
                                </Grid>
                            </Grid>

                            <StackPanel Grid.Row="3"
                                        Orientation="Horizontal"
                                        Margin="0,40,0,0"
                                        VerticalAlignment="Bottom">
                                <StackPanel Margin="0,0,50,0">
                                    <TextBlock Text="Processes"
                                               Foreground="#A0A0A0"
                                               FontSize="14"/>
                                    <TextBlock x:Name="ProcessesCountText"
                                               Text="278"
                                               FontSize="26"
                                               Foreground="White"/>

                                    <TextBlock Text="Up time"
                                               Foreground="#A0A0A0"
                                               FontSize="14"
                                               Margin="0,20,0,0"/>
                                    <TextBlock x:Name="UpTimeText"
                                               Text="0:02:03:42"
                                               FontSize="26"
                                               Foreground="White"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,50,0">
                                    <TextBlock Text="Threads"
                                               Foreground="#A0A0A0"
                                               FontSize="14"/>
                                    <TextBlock x:Name="ThreadsCountText"
                                               Text="4870"
                                               FontSize="26"
                                               Foreground="White"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,50,0">
                                    <TextBlock Text="Handles"
                                               Foreground="#A0A0A0"
                                               FontSize="14"/>
                                    <TextBlock x:Name="HandlesCountText"
                                               Text="163852"
                                               FontSize="26"
                                               Foreground="White"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Memory">
                        <StackPanel Margin="30">
                            <TextBlock Text="RAM"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                            <TextBlock x:Name="RamAmount"
                                       Text="Total RAM..."
                                       FontSize="14"
                                       Foreground="#A0A0A0"
                                       Margin="0,0,0,30"/>
                            <TextBlock x:Name="RamUsage"
                                       Text="0.0 GB"
                                       FontSize="48"
                                       FontWeight="Light"/>
                            <TextBlock Text="In use"
                                       FontSize="14"
                                       Foreground="#A0A0A0"/>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Disk (C:)">
                        <StackPanel Margin="30">
                            <TextBlock Text="Local Disk"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                            <TextBlock x:Name="DiskModel"
                                       Text="Reading unit..."
                                       FontSize="14"
                                       Foreground="#A0A0A0"
                                       Margin="0,0,0,30"/>
                            <TextBlock x:Name="DiskUsage"
                                       Text="0%"
                                       FontSize="48"
                                       FontWeight="Light"/>
                            <TextBlock Text="Active time"
                                       FontSize="14"
                                       Foreground="#A0A0A0"/>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Ethernet">
                        <StackPanel Margin="30">
                            <TextBlock Text="Ethernet / Wi-Fi"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                            <TextBlock x:Name="NetworkName"
                                       Text="Ethernet Adapter"
                                       FontSize="14"
                                       Foreground="#A0A0A0"
                                       Margin="0,0,0,30"/>
                            <TextBlock x:Name="NetSend"
                                       Text="Sending: 0 Kbps"
                                       FontSize="24"
                                       FontWeight="Light"
                                       Margin="0,0,0,10"/>
                            <TextBlock x:Name="NetReceive"
                                       Text="Receiving: 0 Kbps"
                                       FontSize="24"
                                       FontWeight="Light"/>
                        </StackPanel>
                    </TabItem>

                </TabControl>
            </TabItem>
        </TabControl>
    </Grid>
</Window>